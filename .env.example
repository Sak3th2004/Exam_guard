# ExamGuard v2.0 Environment Configuration
# Copy this file to .env and adjust values

# Database
DATABASE_URL=sqlite+aiosqlite:///examguard.db

# CORS Origins (comma-separated)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost"]

# Ollama LLM Configuration
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=mistral:7b

# Engine Hyperparameters
MINHASH_PERMUTATIONS=128
MINHASH_THRESHOLD=0.70
BONFERRONI_ALPHA=0.001
ISOLATION_FOREST_CONTAMINATION=0.05
IRT_ZSCORE_THRESHOLD=3.0
TIMING_CLUSTER_PERCENTILE=2.0

# GNN Configuration
GNN_HIDDEN_DIM=64
GNN_OUTPUT_DIM=32
GNN_LEARNING_RATE=0.01
GNN_EPOCHS=200

# VAE Configuration
VAE_LATENT_DIM=32
VAE_LEARNING_RATE=0.001
VAE_EPOCHS=100

# XGBoost Configuration
XGBOOST_MAX_DEPTH=6
XGBOOST_LEARNING_RATE=0.1
XGBOOST_N_ESTIMATORS=300
