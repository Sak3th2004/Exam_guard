# ExamGuard v2 Environment Configuration
# Copy this to .env and customize as needed

# API Settings
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
DEBUG=true

# GPU Settings
USE_GPU=true
CUDA_DEVICE=cuda:0

# Ollama LLM (for report narration)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=mistral:7b-instruct-v0.2-q4_K_M
OLLAMA_TIMEOUT=60.0

# Detection Thresholds
LSH_THRESHOLD=0.7
LSH_NUM_PERM=128
SIMILARITY_EDGE_THRESHOLD=0.75
BONFERRONI_ALPHA=0.05
BENFORD_ALPHA=0.05
BENFORD_CENTER_ALPHA=0.01

# Risk Tier Thresholds
RISK_CRITICAL_THRESHOLD=0.8
RISK_HIGH_THRESHOLD=0.6
RISK_MEDIUM_THRESHOLD=0.3
